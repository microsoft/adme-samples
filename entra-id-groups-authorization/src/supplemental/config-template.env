# ADME Entra migration config
#
# Keep this file local only. Do not commit any populated copy that contains
# customer-specific values or secrets.
#
# Command-specific usage:
# - inventory requires only:
#     CUSTOMER_TENANT_ID
#     CUSTOMER_CONFIG_DIR
#     OLD_RESOURCE_APP_ID
#   and can optionally use:
#     OLD_RESOURCE_SERVICE_PRINCIPAL_ID
# - migrate api-permissions selects the client app with:
#     ./adme-entra-migration.sh migrate api-permissions --client-id <client-app-id-or-service-principal-id>
# - verify without --client-id validates tenant audience migration and proves
#   Azure CLI delegated token issuance for the target resource scope:
#     ./adme-entra-migration.sh verify
# - verify can select a customer client app for optional app-only token proof:
#     ./adme-entra-migration.sh verify --client-id <client-app-id-or-service-principal-id>
#   CLIENT_SECRET or verify --client-secret enables the proof. API-permission/admin-consent
#   status belongs to adme-entra-inventory.sh; ADME endpoint smoke belongs to test.sh.

# Customer tenant context
CUSTOMER_TENANT_ID="750f6c9b-c047-407d-979d-16a3776a7a8e"
CUSTOMER_CONFIG_DIR="$HOME/.azure-tenant-KSAD2"

# Optional home-tenant context used by simulation and internal validation.
# Real customers typically do not have these values. Uncomment both lines only
# when running simulation or internal validation that has home-tenant access.
# HOME_TENANT_ID="<home-tenant-id>"
# HOME_CONFIG_DIR="$HOME/.azure-tenant-<home>"

# Resource application identifiers
OLD_RESOURCE_APP_ID="dffa82c7-cb2f-4a0a-9e8f-7e86fd7b245e"
NEW_RESOURCE_APP_ID="bd0c9d90-89ad-4bb3-97bc-d787b9f69cdc"
OLD_RESOURCE_IDENTIFIER_URI="https://energy-old.azure.com"
NEW_RESOURCE_IDENTIFIER_URI="https://energy.azure.com"

# Customer-tenant service principal / client identifiers
# Optional for inventory. If omitted, inventory resolves it from OLD_RESOURCE_APP_ID.
OLD_RESOURCE_SERVICE_PRINCIPAL_ID="<old-resource-service-principal-id>"
# Not required for migrate api-permissions or verify; pass --client-id instead.
# verify without --client-id does not read these selected-client identifiers.
CLIENT_APP_ID="<client-app-id>"
CLIENT_SERVICE_PRINCIPAL_ID="<client-service-principal-id>"

# Replacement app permission identifiers
NEW_RESOURCE_SCOPE_ID="66e904da-2872-4e72-bff6-a88a6c4375ea"
NEW_RESOURCE_SCOPE_VALUE="access_as_user"
NEW_RESOURCE_APP_ROLE_ID="f1454897-e4e4-440e-9e04-bc379d7629f7"
NEW_RESOURCE_APP_ROLE_VALUE="ADME.ApplicationAccess"

# Optional app-only token proof secret. Keep local-only if you use it.
# This must be the secret value for the selected verify --client-id app. If it is
# missing, verify --client-id skips the app-only token proof.
# If supplied but invalid, verify reports the app-only failure with remediation.
# CLIENT_SECRET="<client-secret>"
